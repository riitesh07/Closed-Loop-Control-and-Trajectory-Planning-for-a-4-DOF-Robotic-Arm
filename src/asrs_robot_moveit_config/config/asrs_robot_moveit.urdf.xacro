<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="asrs_robot">

  <!-- ROS2 xacro: every arg MUST have a default -->
  <xacro:arg name="robot_xacro_file" default=""/>
  <xacro:arg name="control_xacro_file" default=""/>

  <!-- Include robot geometry + ros2_control -->
  <xacro:include filename="$(arg robot_xacro_file)" />
  <xacro:include filename="$(arg control_xacro_file)" />

  <!-- Call ros2_control macro (Option B: no *_init args) -->
  <xacro:asrs_robot_ros2_control name="asrs_robot" />

</robot>

